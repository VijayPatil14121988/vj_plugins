#!/usr/bin/env bash
# SessionStart hook for Siddhi plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-siddhi content
using_siddhi_content=$(cat "${PLUGIN_ROOT}/skills/using-siddhi/SKILL.md" 2>&1 || echo "Error reading using-siddhi skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_siddhi_escaped=$(escape_for_json "$using_siddhi_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have Siddhi.\n\n**Below is the full content of your 'siddhi:using-siddhi' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_siddhi_escaped}\n\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
